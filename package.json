{
  "name": "offline-wiki-packs",
  "version": "0.1.0",
  "description": "Download a game's wiki for offline reading in Game Mode — guides on the plane, in the tent, on the train.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "wiki",
    "offline",
    "guides"
  ],
  "author": "Sabissimo",
  "license": "MIT",
  "dependencies": {
    "@decky/api": "^1.1.2",
    "@decky/ui": "^4.9.1",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@decky/rollup": "^1.0.1",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "rollup": "^4.28.1",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
